{
  "regions": ["fra1"],
  "buildCommand": "npm run build",
  "rewrites": [
    {
      "source": "/dist/(.*)",
      "destination": "/web/dist/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.go"
    }
  ],
  "headers": [
    {
      "source": "/dist/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
