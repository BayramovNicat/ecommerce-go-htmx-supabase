{
	"regions": ["fra1"],
	"buildCommand": "npm run build",
	"routes": [
		{
			"src": "/dist/(.*)",
			"dest": "/web/dist/$1",
			"headers": {
				"Cache-Control": "public, max-age=31536000, immutable"
			}
		},
		{
			"src": "/(.*)",
			"dest": "/api/index.go"
		}
	],
	"headers": [
		{
			"source": "/products/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=300, stale-while-revalidate=600"
				}
			]
		}
	]
}
