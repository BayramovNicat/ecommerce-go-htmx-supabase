{
  "name": "htmxshop",
  "version": "1.0.0",
  "description": "HTMX Shop with Tailwind CSS",
  "scripts": {
    "build:css": "tailwindcss -i ./styles/input.css -o ./public/styles.css -m",
    "watch:css": "tailwindcss -i ./styles/input.css -o ./public/styles.css -w",
    "build:js": "esbuild scripts/bundle.js --bundle --minify --outfile=public/bundle.js",
    "build": "npm run build:css && npm run build:js",
    "watch:js": "esbuild scripts/bundle.js --bundle --outfile=public/bundle.js --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "alpinejs": "^3.15.11",
    "esbuild": "^0.28.0",
    "htmx.org": "^2.0.8",
    "tailwindcss": "^4.2.2"
  }
}
